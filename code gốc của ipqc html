<!DOCTYPE html><html lang="vi"><head>    <meta charset="UTF-8">    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">    <title>SOP IPQC PRO MAX</title>    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>    <style>        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap');        :root { --red: #d63031; --dark: #2d3436; --bg: #f0f2f5; --border: #b2bec3; --success: #2ecc71; --warning: #f1c40f; --blue: #0984e3; }        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; font-family: 'Inter', -apple-system, sans-serif; touch-action: manipulation; }        body { background: var(--bg); margin: 0; padding: 0; display: flex; justify-content: center; overflow-x: hidden; }        body.edit-mode { -webkit-user-select: auto; user-select: auto; }        #export-container { width: 100vw; max-width: 500px; min-height: 100vh; padding: 20px; padding-bottom: 150px; background: var(--bg); position: relative; }        .header-box { background: linear-gradient(135deg, var(--dark) 0%, #444 100%); border: 3px solid #000; border-bottom: 10px solid #000; border-radius: 30px; padding: 25px 15px; margin-bottom: 20px; text-align: center; }        .header-box h1 { margin: 0; font-weight: 900; color: #fff; font-size: 1.8rem; text-shadow: 2px 2px 0px var(--red); }        .ai-area { background: #fff; border-radius: 20px; padding: 15px; margin-bottom: 20px; border: 2px dashed var(--red); display: none; }        body.edit-mode .ai-area { display: block; }        #ai-input { min-height: 60px; outline: none; border: 1px solid #eee; padding: 10px; margin-bottom: 10px; border-radius: 10px; font-size: 16px; background: #fafafa; }        .info-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 25px; }        .info-card { background: #fff; padding: 12px 5px; text-align: center; border-radius: 18px; border: 3px solid var(--dark); border-bottom: 6px solid var(--dark); }        .info-card label { font-size: 9px; font-weight: 900; color: #fff; background: var(--red); display: inline-block; padding: 2px 6px; border-radius: 4px; margin-bottom: 5px; }        .info-card span { font-size: 13px; font-weight: 900; color: var(--dark); display: block; min-height: 18px; outline: none; }
        .step-box { background: #fff; border-radius: 25px; padding: 20px; margin-bottom: 20px; border: 2px solid var(--border); border-bottom: 6px solid var(--border); position: relative; width: 100%; clear: both; transition: 0.3s; }
        .step-num { position: absolute; top: -15px; left: -10px; width: 45px; height: 45px; background: var(--dark); color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 20px; border: 4px solid #fff; box-shadow: 0 4px 10px rgba(0,0,0,0.2); }
        .step-box.box-pass { border-color: var(--success); border-bottom-color: #1e8449; background: #fafff5; }
        .step-box.box-ng { border-color: var(--red); border-bottom-color: #8a2828; background: #fff5f5; }
        .step-box.box-note { border-color: var(--warning); border-bottom-color: #d4ac0d; background: #fffdf0; }
        /* Hiệu ứng rung khung */
        @keyframes shake { 0% { transform: translateX(0); } 25% { transform: translateX(5px); } 50% { transform: translateX(-5px); } 75% { transform: translateX(5px); } 100% { transform: translateX(0); } }
        .shake-limit { animation: shake 0.2s ease-in-out; }
        .editor { min-height: 60px; font-size: 16px; line-height: 1.6; outline: none; word-wrap: break-word; padding-top: 10px; width: 100%; }
        .editor img { max-width: 100%; border-radius: 10px; margin-top: 10px; border: 2px solid #ddd; }
        .status-row { display: flex; justify-content: space-between; gap: 10px; margin-top: 20px; width: 100%; }
        body.edit-mode .status-row { display: none !important; }
        /* Ẩn khi xuất PDF */
        body.exporting .status-row, body.exporting .edit-row, body.exporting .ins-btn, body.exporting .ai-area { display: none !important; }
        .s-btn { flex: 1; height: 55px; border-radius: 15px; border: 2px solid var(--border); background: #fff; font-size: 11px; font-weight: 900; border-bottom: 5px solid var(--border); cursor: pointer; }
        .s-btn.active.pass { background: var(--success); color: #fff; border-color: #2ecc71; border-bottom-color: #1e8449; }
        .s-btn.active.ng { background: var(--red); color: #fff; border-color: #d63031; border-bottom-color: #8a2828; }
        .s-btn.active.note { background: var(--warning); color: #fff; border-color: #f1c40f; border-bottom-color: #9a7d0a; }
        .mega-toolbar { position: fixed; bottom: 85px; left: 10px; right: 10px; background: #fff; border: 2px solid var(--dark); display: none; z-index: 10001; border-radius: 15px; box-shadow: 0 5px 20px rgba(0,0,0,0.1); padding: 8px; }
        .mega-toolbar.active { display: block; }
        .t-scroll { display: flex; overflow-x: auto; gap: 8px; padding-bottom: 2px; justify-content: center; -webkit-overflow-scrolling: touch; }
        .t-tool { min-width: 42px; height: 42px; flex-shrink: 0; border-radius: 10px; border: 1.5px solid #eee; background: #f8f9fa; font-weight: 800; display: flex; align-items: center; justify-content: center; font-size: 14px; cursor: pointer; color: #555; }
        .t-tool.on { background: #ddd; color: #000; border-color: #bbb; }
        .fab { position: fixed; bottom: 15px; right: 15px; width: 55px; height: 55px; background: var(--dark); border-radius: 50%; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 22px; border-bottom: 5px solid #000; z-index: 10000; }
        .panel { position: fixed; bottom: 80px; right: 15px; width: 200px; background: #fff; border-radius: 20px; padding: 12px; display: none; border: 3px solid var(--dark); z-index: 9999; flex-direction: column; gap: 8px; }
        .panel.active { display: flex; }
        .ui-btn { padding: 12px; border-radius: 12px; border: 2.5px solid #ddd; font-weight: 800; font-size: 10px; cursor: pointer; background: #fff; border-bottom: 4px solid #ddd; }
        .edit-row { display: none; gap: 5px; margin-top: 10px; } body.edit-mode .edit-row { display: flex !important; }
        .del-btn { flex: 1; height: 38px; border-radius: 10px; background: #fff; color: var(--red); border: 1.5px dashed var(--red); font-weight: 800; font-size: 10px; }
        .ins-btn { width: 100%; height: 40px; border-radius: 12px; border: 2px dashed #ccc; margin: 10px 0; color: #aaa; font-weight: 800; display: none; align-items: center; justify-content: center; font-size: 12px; } body.edit-mode .ins-btn { display: flex; }    </style></head><body>

<div id="export-container">
    <div class="header-box"><h1>SỔ TAY IPQC</h1><div style="font-size:11px; font-weight:800; color:var(--warning); margin-top:5px;">阮青江 - QUALITY CONTROL</div></div>
    <div class="ai-area"><div id="ai-input" contenteditable="true" placeholder="Dán nội dung..."></div><button class="ui-btn" style="width:100%; background:var(--dark); color:#fff;" onclick="importAI()">⚡ CHIA BƯỚC TỰ ĐỘNG</button></div>
    <div class="info-grid">
        <div class="info-card"><label>MÃ HÀNG</label><span id="v1" contenteditable="false">---</span></div>
        <div class="info-card"><label>NỘI BỘ</label><span id="v2" contenteditable="false">---</span></div>
        <div class="info-card"><label>KHÁCH</label><span id="v3" contenteditable="false">---</span></div>
    </div>
    <div id="step-list"></div>
</div>

<div class="fab" onclick="toggle('.panel')">⚙</div>
<div class="panel">
    <button class="ui-btn" onclick="toggleEdit()" id="ebtn">🛠 CHẾ ĐỘ CHỈNH SỬA</button>
    <button class="ui-btn" style="display: none;" id="add-btn" onclick="addS()">➕ THÊM BƯỚC MỚI</button>
    <button class="ui-btn" onclick="clearAll()" style="color:var(--red)">🗑 XÓA TẤT CẢ BƯỚC</button>
    <button class="ui-btn" onclick="resetStatus()" style="color:var(--success)">🔄 RESET TRẠNG THÁI</button>
    <button class="ui-btn" onclick="exportPDF(2)" style="color:var(--blue)">📄 XUẤT FILE PDF</button>
    <button class="ui-btn" onclick="authSave()" style="background:var(--dark); color:#fff;">💾 LƯU FILE HTML</button>
</div>

<button id="toolbar-trigger" style="position: fixed; bottom: 15px; left: 15px; width: 55px; height: 55px; border-radius: 50%; background: #fff; border: 3px solid var(--dark); font-weight: 900; z-index: 10000; display:none;" onmousedown="event.preventDefault(); toggle('.mega-toolbar')">A</button>

<div class="mega-toolbar">
    <div class="t-scroll">
        <button class="t-tool" onmousedown="btnExec(event, 'bold')"><b>B</b></button>
        <button class="t-tool" onmousedown="btnExec(event, 'italic')"><i>I</i></button>
        <button class="t-tool" onmousedown="btnExec(event, 'underline')"><u>U</u></button>
        <button class="t-tool" onmousedown="btnSize(event, 2)">A+</button>
        <button class="t-tool" onmousedown="btnSize(event, -2)">A-</button>
        <button class="t-tool" onmousedown="btnExec(event, 'insertUnorderedList')">•=</button>
        <button class="t-tool" onmousedown="btnExec(event, 'insertOrderedList')">1.</button>
        <button class="t-tool" onmousedown="btnImage(event)">📷</button>
        <button class="t-tool" id="btn-hilite" onmousedown="toggleExec(event, 'hiliteColor', 'yellow', 'btn-hilite')">🖍️</button>
        <button class="t-tool" id="btn-red" onmousedown="toggleExec(event, 'foreColor', '#d63031', 'btn-red')"><span style="color:#d63031">🖋️</span></button>
        <button class="t-tool" onmousedown="btnTable(event)">田</button>
        <button class="t-tool" onmousedown="btnExec(event, 'removeFormat')">🧹</button>
    </div>
</div>

<script type="application/json" id="db">{"v1":"---","v2":"---","v3":"---","c":""}</script>
<script>    let isEdit = false; let activeEd = null;
    let hiliteMode = false; let redMode = false;
    const SAVE_PASS = "111983";

    window.onload = () => {        
        let d = JSON.parse(document.getElementById('db').textContent);        
        if(d.c) document.getElementById('step-list').innerHTML = d.c;        
        document.getElementById('v1').innerText = d.v1; document.getElementById('v2').innerText = d.v2; document.getElementById('v3').innerText = d.v3;                
        reIdx(); attach();    
    };

    function authSave() {
        let p = prompt("NHẬP MẬT KHẨU ĐỂ LƯU FILE:");
        if (p === SAVE_PASS) saveData(); else alert("Sai mật khẩu!");
    }

    function toggleExec(e, cmd, val, btnId) {
        e.preventDefault(); if(!isEdit || !activeEd) return;
        let mode; if(btnId === 'btn-hilite') mode = hiliteMode = !hiliteMode; if(btnId === 'btn-red') mode = redMode = !redMode;
        const btn = document.getElementById(btnId);
        if(mode) { btn.classList.add('on'); document.execCommand(cmd, false, val); } 
        else { btn.classList.remove('on'); if(btnId === 'btn-hilite') document.execCommand('hiliteColor', false, 'transparent'); if(btnId === 'btn-red') document.execCommand('foreColor', false, '#000000'); }
        activeEd.focus();
    }

    function btnImage(e) {
        e.preventDefault(); const input = document.createElement('input'); input.type = 'file'; input.accept = 'image/*';
        input.onchange = (ev) => {
            const file = ev.target.files[0]; const reader = new FileReader();
            reader.onload = (re) => { const img = `<img src="${re.target.result}">`; document.execCommand('insertHTML', false, img); };
            reader.readAsDataURL(file);
        };
        input.click();
    }

    function toggleEdit() { isEdit = !isEdit; document.body.classList.toggle('edit-mode', isEdit); document.getElementById('ebtn').innerText = isEdit ? "🔒 KHÓA" : "🛠 SỬA"; document.getElementById('add-btn').style.display = isEdit ? 'flex' : 'none'; document.getElementById('toolbar-trigger').style.display = isEdit ? 'block' : 'none'; document.querySelectorAll('.editor, #v1, #v2, #v3').forEach(e => e.contentEditable = isEdit); if(!isEdit) { document.querySelectorAll('.panel, .mega-toolbar').forEach(p => p.classList.remove('active')); hiliteMode = false; redMode = false; document.querySelectorAll('.t-tool').forEach(b => b.classList.remove('on')); } }
    function attach() { document.querySelectorAll('.editor').forEach(e => { e.onfocus = () => { activeEd = e; if(isEdit) document.querySelector('.mega-toolbar').classList.add('active'); }; }); }    
    function getHtml(txt = "Nội dung...") { return `<div class="step-box"><div class="step-num n"></div><div class="editor" contenteditable="${isEdit}">${txt}</div><div class="status-row"><button class="s-btn pass" onclick="toggleStatus(this, 'box-pass')">PASS</button><button class="s-btn ng" onclick="toggleStatus(this, 'box-ng')">NG</button><button class="s-btn note" onclick="toggleStatus(this, 'box-note')">LƯU Ý</button></div><div class="edit-row"><button class="del-btn" onclick="delS(this)">🗑 XÓA</button><button class="del-btn" style="border-color:#ccc; color:#666" onclick="copyS(this)">📋 COPY</button></div></div><div class="ins-btn" onclick="insS(this)">+ CHÈN BƯỚC MỚI</div>`; }    
    function addS() { document.getElementById('step-list').insertAdjacentHTML('beforeend', getHtml()); reIdx(); attach(); }    
    function insS(b) { b.insertAdjacentHTML('afterend', getHtml()); reIdx(); attach(); }    
    function copyS(b) { const c = b.closest('.step-box').querySelector('.editor').innerHTML; b.closest('.step-box').insertAdjacentHTML('afterend', getHtml(c)); reIdx(); attach(); }    
    function delS(b) { if(confirm('Xóa?')) { b.closest('.step-box').nextElementSibling.remove(); b.closest('.step-box').remove(); reIdx(); } }    
    function clearAll() { if(confirm('BẠN MUỐN XÓA TẤT CẢ CÁC BƯỚC?')) { document.getElementById('step-list').innerHTML = ""; } }
    function reIdx() { document.querySelectorAll('.n').forEach((e, i) => e.innerText = i + 1); }
    
    function toggleStatus(btn, cls) { 
        if(isEdit) return; 
        if (window.navigator.vibrate) window.navigator.vibrate(50);
        const box = btn.closest('.step-box'); 
        box.classList.add('shake-limit'); setTimeout(() => box.classList.remove('shake-limit'), 300); // Hiệu ứng rung khung
        const active = btn.classList.contains('active'); 
        btn.parentElement.querySelectorAll('.s-btn').forEach(b => b.classList.remove('active')); 
        box.classList.remove('box-pass', 'box-ng', 'box-note'); 
        if(!active) { btn.classList.add('active'); box.classList.add(cls); } 
    }
    
    function btnExec(e, cmd, val=null) { e.preventDefault(); if(isEdit && activeEd) { document.execCommand(cmd, false, val); activeEd.focus(); } }
    function btnSize(e, step) { e.preventDefault(); if(!isEdit || !activeEd) return; let cur = document.queryCommandValue("fontSize") || 3; let next = Math.max(1, Math.min(7, parseInt(cur) + (step > 0 ? 1 : -1))); document.execCommand("fontSize", false, next); activeEd.focus(); }
    function btnTable(e) { e.preventDefault(); let r = prompt("Hàng:", "2"), c = prompt("Cột:", "2"); if(r && c) { let h = `<div class="table-wrapper"><table border="1" style="width:100%;border-collapse:collapse;">`; for(let i=0; i<r; i++) { h += `<tr>`; for(let j=0; j<c; j++) h += `<td style="border:1px solid #ccc;padding:8px;">&nbsp;</td>`; h += `</tr>`; } h += `</table></div><p></p>`; document.execCommand('insertHTML', false, h); } }
    function toggle(cls) { const el = document.querySelector(cls); const act = el.classList.contains('active'); document.querySelectorAll('.panel, .mega-toolbar').forEach(p => p.classList.remove('active')); if(!act) el.classList.add('active'); }
    function importAI() { const inp = document.getElementById('ai-input'); const rawText = inp.innerText.trim(); if(!rawText) return; rawText.split(/\(STEP\)/gi).forEach(p => { if(p.trim()) { const clean = p.trim().replace(/\n/g, '<br>'); document.getElementById('step-list').insertAdjacentHTML('beforeend', getHtml(clean)); } }); inp.innerHTML = ""; reIdx(); attach(); }
    function saveData() { if(isEdit) toggleEdit(); const d = { v1: document.getElementById('v1').innerText, v2: document.getElementById('v2').innerText, v3: document.getElementById('v3').innerText, c: document.getElementById('step-list').innerHTML }; const clone = document.documentElement.cloneNode(true); clone.querySelector('#db').textContent = JSON.stringify(d); const blob = new Blob(["<!DOCTYPE html>\n" + clone.outerHTML], {type:'text/html'}); const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = `SOP_IPQC.html`; a.click(); }
    
    async function exportPDF(quality) { 
        if(isEdit) toggleEdit(); 
        document.body.classList.add('exporting'); // Bật chế độ ẩn nút
        setTimeout(() => {
            html2canvas(document.getElementById('export-container'), { scale: quality, useCORS: true }).then(cv => { 
                const pdf = new jspdf.jsPDF('p', 'mm', [210, (cv.height * 210) / cv.width]); 
                pdf.addImage(cv.toDataURL('image/jpeg', 0.95), 'JPEG', 0, 0, 210, (cv.height * 210) / cv.width); 
                pdf.save(`SOP_IPQC_CLEAN.pdf`); 
                document.body.classList.remove('exporting'); // Hiện lại nút sau khi xuất
            }); 
        }, 100);
    }
    
    function resetStatus() { if(confirm("Xóa dấu?")) { document.querySelectorAll('.step-box').forEach(box => { box.classList.remove('box-pass', 'box-ng', 'box-note', 'shake-limit'); box.querySelectorAll('.s-btn').forEach(btn => btn.classList.remove('active')); }); } }
</script>
</body></html>
